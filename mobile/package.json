{
  "name": "music",
  "private": true,
  "main": "index.ts",
  "version": "3.1.0-rc.1",
  "description": "A Nothing inspired music player.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/MissingCore/Music"
  },
  "author": "cyanChill",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android --variant debugOptimized",
    "android:prod": "expo run:android --variant release",
    "atlas": "npx expo export --platform android && npx expo-atlas",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "circular-dep": "npx dpdm@4.0.1 ./src/* --circular --exit-code circular:1 --warning=false",
    "db:generate": "drizzle-kit generate",
    "sync:licenses": "license-checker-rseidelsohn --production --depth=0 --excludePrivatePackages --clarificationsFile ./scripts/licenses/licenseClarification.json --customPath ./scripts/licenses/customLicenseFormat.json --json | node ./scripts/licenses/updateLicenses.mjs",
    "release": "git pull && python ./scripts/release/release_bump.py"
  },
  "dependencies": {
    "@boterop/react-native-background-timer": "2.6.0",
    "@legendapp/list": "2.0.19",
    "@lodev09/react-native-true-sheet": "3.4.2",
    "@missingcore/music-glyph-toys": "github:MissingCore/music-glyph-toys#01731b075e273a490b74cd23159abf36acc83b40",
    "@missingcore/react-native-actual-path": "0.1.0",
    "@missingcore/react-native-audio-analyzer": "3.2.0-beta.4",
    "@missingcore/react-native-metadata-retriever": "3.0.0",
    "@paralleldrive/cuid2": "3.3.0",
    "@react-navigation/material-top-tabs": "7.4.27",
    "@react-navigation/native": "7.2.4",
    "@react-navigation/native-stack": "7.15.1",
    "@rn-primitives/portal": "1.4.0",
    "@sentry/react-native": "8.11.1",
    "@tanstack/react-query": "5.100.10",
    "@zoontek/react-native-navigation-bar": "1.1.2",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "expo": "55.0.24",
    "expo-device": "55.0.17",
    "expo-document-picker": "55.0.13",
    "expo-drizzle-studio-plugin": "0.2.1",
    "expo-file-system": "55.0.20",
    "expo-font": "55.0.7",
    "expo-image": "55.0.10",
    "expo-image-manipulator": "55.0.16",
    "expo-image-picker": "55.0.20",
    "expo-linear-gradient": "55.0.14",
    "expo-localization": "55.0.14",
    "expo-media-library": "55.0.17",
    "expo-sqlite": "55.0.16",
    "expo-web-browser": "55.0.16",
    "i18next": "26.1.0",
    "intl-pluralrules": "2.0.1",
    "jotai": "2.20.0",
    "react": "19.2.0",
    "react-i18next": "17.0.7",
    "react-native": "0.83.9",
    "react-native-android-widget": "0.20.3",
    "react-native-audio-browser": "github:MissingCore/react-native-audio-browser#09f9173290bd305fbd716de4aa1b8ce0a68e118c",
    "react-native-bootsplash": "7.3.1",
    "react-native-gesture-handler": "2.31.2",
    "react-native-keyboard-controller": "1.21.7",
    "react-native-markdown-renderer": "4.1.1",
    "react-native-nitro-modules": "0.35.6",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-reorderable-list": "0.18.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.0",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.8.3",
    "reanimated-color-picker": "4.2.0",
    "tailwind-merge": "3.6.0",
    "uniwind": "1.6.5",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@tanstack/eslint-plugin-query": "5.100.10",
    "@types/react": "19.2.14",
    "babel-plugin-inline-import": "3.0.0",
    "babel-plugin-transform-remove-console": "6.9.4",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-expo": "55.0.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-drizzle": "0.2.3",
    "eslint-plugin-prettier": "5.5.5",
    "expo-atlas": "0.4.3",
    "expo-build-properties": "55.0.14",
    "license-checker-rseidelsohn": "4.4.2",
    "neatjson": "0.10.6",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-splash-screen"
      ]
    }
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": false,
      "DISABLE_COMMIT_PAUSING_MECHANISM": false,
      "EXPERIMENTAL_CSS_ANIMATIONS_FOR_SVG_COMPONENTS": true
    }
  }
}

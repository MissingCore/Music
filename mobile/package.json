{
  "name": "music",
  "private": true,
  "main": "index.ts",
  "version": "3.1.0",
  "description": "A Nothing inspired music player.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/MissingCore/Music"
  },
  "author": "cyanChill",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android --variant debugOptimized",
    "android:prod": "expo run:android --variant release",
    "atlas": "npx expo export --platform android && npx expo-atlas",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "circular-dep": "npx dpdm@4.0.1 ./src/* --circular --exit-code circular:1 --warning=false",
    "db:generate": "drizzle-kit generate",
    "sync:licenses": "license-checker-rseidelsohn --production --depth=0 --excludePrivatePackages --clarificationsFile ./scripts/licenses/licenseClarification.json --customPath ./scripts/licenses/customLicenseFormat.json --json | node ./scripts/licenses/updateLicenses.mjs",
    "release": "git pull && python ./scripts/release/release_bump.py"
  },
  "dependencies": {
    "@boterop/react-native-background-timer": "2.6.0",
    "@legendapp/list": "3.0.0",
    "@lodev09/react-native-true-sheet": "3.4.2",
    "@missingcore/music-glyph-toys": "github:MissingCore/music-glyph-toys#f34db01c67b218ccd3085ddb5e2d135399445bef",
    "@missingcore/react-native-actual-path": "0.1.0",
    "@missingcore/react-native-audio-analyzer": "3.2.0-beta.4",
    "@missingcore/react-native-metadata-retriever": "github:MissingCore/react-native-metadata-retriever#0b8240abae2645febc30fc8ed74aa63af47f269f",
    "@paralleldrive/cuid2": "3.3.0",
    "@react-navigation/material-top-tabs": "7.4.28",
    "@react-navigation/native": "7.2.5",
    "@react-navigation/native-stack": "7.16.0",
    "@rn-primitives/portal": "1.4.0",
    "@sentry/react-native": "8.13.0",
    "@tanstack/react-query": "5.100.14",
    "@zoontek/react-native-navigation-bar": "1.1.2",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "expo": "56.0.8",
    "expo-drizzle-studio-plugin": "0.2.1",
    "expo-file-system": "56.0.7",
    "expo-font": "56.0.5",
    "expo-image": "56.0.9",
    "expo-image-manipulator": "56.0.16",
    "expo-image-picker": "56.0.15",
    "expo-linear-gradient": "56.0.4",
    "expo-media-library": "56.0.6",
    "expo-sqlite": "56.0.4",
    "i18next": "26.3.0",
    "intl-pluralrules": "2.0.1",
    "jotai": "2.20.0",
    "react": "19.2.3",
    "react-i18next": "17.0.8",
    "react-native": "0.85.3",
    "react-native-android-widget": "0.20.3",
    "react-native-audio-browser": "github:MissingCore/react-native-audio-browser#8900e386b4c69c3c4068bc8f062e52ad5fb2196a",
    "react-native-bootsplash": "7.3.1",
    "react-native-gesture-handler": "3.0.0",
    "react-native-keyboard-controller": "1.21.8",
    "react-native-markdown-renderer": "4.1.1",
    "react-native-nitro-modules": "0.35.9",
    "react-native-pager-view": "8.0.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "3.6.0",
    "uniwind": "1.7.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@tanstack/eslint-plugin-query": "5.100.14",
    "@types/react": "19.2.15",
    "babel-plugin-inline-import": "3.0.0",
    "babel-plugin-transform-remove-console": "6.9.4",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-drizzle": "0.2.3",
    "eslint-plugin-prettier": "5.5.6",
    "expo-atlas": "0.4.3",
    "expo-build-properties": "56.0.16",
    "license-checker-rseidelsohn": "4.4.2",
    "neatjson": "0.10.6",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-splash-screen"
      ]
    }
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": false,
      "DISABLE_COMMIT_PAUSING_MECHANISM": false,
      "EXPERIMENTAL_CSS_ANIMATIONS_FOR_SVG_COMPONENTS": true
    }
  }
}

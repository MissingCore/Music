{
  "name": "music",
  "private": true,
  "main": "index.ts",
  "version": "3.0.0-rc.4",
  "description": "A Nothing inspired music player.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/MissingCore/Music"
  },
  "author": "cyanChill",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android --variant debugOptimized",
    "android:prod": "expo run:android --variant release",
    "atlas": "npx expo export --platform android && npx expo-atlas",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "circular-dep": "npx dpdm ./src/* --circular --exit-code circular:1 --warning=false",
    "db:generate": "drizzle-kit generate",
    "sync:licenses": "license-checker-rseidelsohn --production --depth=0 --excludePrivatePackages --clarificationsFile ./scripts/licenses/licenseClarification.json --customPath ./scripts/licenses/customLicenseFormat.json --json | node ./scripts/licenses/updateLicenses.mjs",
    "release": "git pull && python ./scripts/release/release_bump.py"
  },
  "dependencies": {
    "@boterop/react-native-background-timer": "2.6.0",
    "@kaannn/react-native-waveform": "0.1.4",
    "@legendapp/list": "2.0.19",
    "@lodev09/react-native-true-sheet": "3.4.2",
    "@lukemorales/query-key-factory": "1.3.4",
    "@missingcore/music-glyph-toys": "github:MissingCore/music-glyph-toys#bbd70768ca76dff4a585905f02ea6f60c9cd2f38",
    "@missingcore/react-native-actual-path": "0.1.0",
    "@missingcore/react-native-audio-analyzer": "3.2.0-beta.3",
    "@missingcore/react-native-metadata-retriever": "3.0.0-beta.1",
    "@paralleldrive/cuid2": "3.3.0",
    "@react-navigation/material-top-tabs": "7.4.20",
    "@react-navigation/native": "7.1.34",
    "@react-navigation/native-stack": "7.14.6",
    "@sentry/react-native": "8.5.0",
    "@tanstack/react-query": "5.91.2",
    "@zoontek/react-native-navigation-bar": "1.1.0",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "expo": "55.0.8",
    "expo-device": "55.0.10",
    "expo-document-picker": "55.0.9",
    "expo-drizzle-studio-plugin": "0.2.1",
    "expo-file-system": "55.0.11",
    "expo-image": "55.0.6",
    "expo-image-manipulator": "55.0.11",
    "expo-image-picker": "55.0.13",
    "expo-linear-gradient": "55.0.9",
    "expo-localization": "55.0.9",
    "expo-media-library": "55.0.10",
    "expo-sqlite": "55.0.11",
    "expo-web-browser": "55.0.10",
    "i18next": "25.8.20",
    "intl-pluralrules": "2.0.1",
    "jotai": "2.18.1",
    "react": "19.2.0",
    "react-i18next": "16.5.8",
    "react-native": "0.83.4",
    "react-native-android-widget": "0.20.1",
    "react-native-audio-browser": "github:MissingCore/react-native-audio-browser#9927e718e68c55dc0c5ef57030ed340b63ba96f3",
    "react-native-bootsplash": "7.1.0",
    "react-native-gesture-handler": "2.30.0",
    "react-native-keyboard-controller": "1.21.0",
    "react-native-markdown-display": "7.0.2",
    "react-native-nitro-modules": "0.35.2",
    "react-native-pager-view": "8.0.0",
    "react-native-paper": "5.15.0",
    "react-native-reanimated": "4.2.2",
    "react-native-reorderable-list": "0.18.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "3.5.0",
    "uniwind": "1.6.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@tanstack/eslint-plugin-query": "5.91.5",
    "@types/react": "19.2.14",
    "babel-plugin-inline-import": "3.0.0",
    "babel-plugin-transform-remove-console": "6.9.4",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.2",
    "eslint-config-expo": "55.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-drizzle": "0.2.3",
    "eslint-plugin-prettier": "5.5.5",
    "expo-atlas": "0.4.3",
    "expo-build-properties": "55.0.10",
    "license-checker-rseidelsohn": "4.4.2",
    "neatjson": "0.10.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-splash-screen"
      ]
    }
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": false,
      "DISABLE_COMMIT_PAUSING_MECHANISM": false,
      "USE_COMMIT_HOOK_ONLY_FOR_REACT_COMMITS": true,
      "USE_SYNCHRONIZABLE_FOR_MUTABLES": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@missingcore/music-glyph-toys",
      "@sentry/cli",
      "react-native-audio-browser",
      "sharp"
    ],
    "overrides": {
      "markdown-it": "14.1.1"
    },
    "patchedDependencies": {
      "react-native-android-widget": "patches/react-native-android-widget.patch",
      "@kaannn/react-native-waveform": "patches/@kaannn__react-native-waveform.patch",
      "@lodev09/react-native-true-sheet": "patches/@lodev09__react-native-true-sheet.patch",
      "react-native-paper": "patches/react-native-paper.patch",
      "react-native": "patches/react-native.patch"
    }
  }
}

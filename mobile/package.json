{
  "name": "music",
  "private": true,
  "main": "index.ts",
  "version": "2.8.3",
  "description": "A Nothing inspired music player.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/MissingCore/Music"
  },
  "author": "cyanChill",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:prod": "expo run:android --variant release",
    "atlas": "npx expo export --platform android && npx expo-atlas",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "circular-dep": "npx dpdm ./src/* --circular --exit-code circular:1 --warning=false",
    "db:generate": "drizzle-kit generate",
    "gen:splashscreen": "npx react-native-bootsplash generate --platforms android --background #F2F2F2 ./assets/splash-icon.png",
    "sync:licenses": "license-checker-rseidelsohn --production --depth=0 --excludePrivatePackages --clarificationsFile ./scripts/licenses/licenseClarification.json --customPath ./scripts/licenses/customLicenseFormat.json --json | node ./scripts/licenses/updateLicenses.mjs",
    "release": "git pull && python ./scripts/release/release_bump.py"
  },
  "dependencies": {
    "@backpackapp-io/react-native-toast": "0.13.0",
    "@boterop/react-native-background-timer": "2.6.0",
    "@kaannn/react-native-waveform": "0.1.4",
    "@legendapp/list": "^2.0.19",
    "@lodev09/react-native-true-sheet": "3.4.2",
    "@lukemorales/query-key-factory": "1.3.4",
    "@missingcore/react-native-actual-path": "0.1.0",
    "@missingcore/react-native-metadata-retriever": "2.4.0",
    "@paralleldrive/cuid2": "3.3.0",
    "@react-navigation/material-top-tabs": "7.4.13",
    "@react-navigation/native": "7.1.28",
    "@react-navigation/native-stack": "7.11.0",
    "@sentry/react-native": "7.3.0",
    "@shopify/flash-list": "2.2.0",
    "@tanstack/react-query": "5.90.20",
    "@weights-ai/react-native-track-player": "github:MissingCore/react-native-track-player#74325fcbff1af92006d31791bcca493985f94550",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "expo": "54.0.32",
    "expo-device": "8.0.10",
    "expo-document-picker": "14.0.8",
    "expo-drizzle-studio-plugin": "0.2.1",
    "expo-file-system": "19.0.21",
    "expo-image": "3.0.11",
    "expo-image-manipulator": "14.0.8",
    "expo-image-picker": "17.0.10",
    "expo-linear-gradient": "15.0.8",
    "expo-localization": "17.0.8",
    "expo-media-library": "18.2.1",
    "expo-sqlite": "16.0.10",
    "expo-web-browser": "15.0.10",
    "i18next": "25.8.0",
    "intl-pluralrules": "2.0.1",
    "jotai": "2.17.0",
    "react": "19.1.0",
    "react-i18next": "16.5.4",
    "react-native": "0.81.5",
    "react-native-android-widget": "0.20.1",
    "react-native-audio-analyzer": "3.1.0",
    "react-native-bootsplash": "6.3.12",
    "react-native-draglist": "github:MissingCore/react-native-draglist#7471bc8c12544e6eef7b39be63fd268bc36430e1",
    "react-native-edge-to-edge": "1.7.0",
    "react-native-gesture-handler": "2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-markdown-display": "7.0.2",
    "react-native-nitro-modules": "0.33.2",
    "react-native-pager-view": "8.0.0",
    "react-native-paper": "5.14.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.20.0",
    "react-native-svg": "15.15.1",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "3.4.0",
    "uniwind": "1.2.7",
    "zod": "4.3.6",
    "zustand": "5.0.10"
  },
  "devDependencies": {
    "@babel/core": "7.28.6",
    "@tanstack/eslint-plugin-query": "5.91.3",
    "@types/react": "19.1.17",
    "babel-plugin-inline-import": "3.0.0",
    "babel-plugin-transform-remove-console": "6.9.4",
    "drizzle-kit": "0.31.8",
    "eslint": "9.39.2",
    "eslint-config-expo": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-drizzle": "0.2.3",
    "eslint-plugin-prettier": "5.5.5",
    "expo-atlas": "0.4.3",
    "expo-build-properties": "1.0.10",
    "license-checker-rseidelsohn": "4.4.2",
    "neatjson": "0.10.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-splash-screen"
      ]
    }
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": false
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@weights-ai/react-native-track-player",
      "react-native-draglist",
      "sharp"
    ],
    "overrides": {
      "markdown-it": "14.1.0"
    },
    "patchedDependencies": {
      "@backpackapp-io/react-native-toast": "patches/@backpackapp-io__react-native-toast.patch",
      "react-native-android-widget": "patches/react-native-android-widget.patch",
      "react-native-bootsplash": "patches/react-native-bootsplash.patch",
      "@kaannn/react-native-waveform": "patches/@kaannn__react-native-waveform.patch",
      "@lodev09/react-native-true-sheet": "patches/@lodev09__react-native-true-sheet.patch",
      "react-native-paper": "patches/react-native-paper.patch"
    }
  }
}

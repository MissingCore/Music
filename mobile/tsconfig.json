{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@missingcore/native-utils": ["./modules/native-utils"],
      "@missingcore/toast": ["./modules/toast"],
      "~/*": ["./src/*"]
    },
    "noUncheckedIndexedAccess": true
  },
  "include": [
    ".eslintrc.js",
    "**/*.js",
    "**/*.mjs",
    "**/*.ts",
    "**/*.tsx",
    "uniwind-types.d.ts"
  ],
  "exclude": ["node_modules"]
}
